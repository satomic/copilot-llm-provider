# =============================================================================
# Copilot LLM Provider — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.

# -----------------------------------------------------------------------------
# GitHub Authentication
# -----------------------------------------------------------------------------
# GitHub personal access token with Copilot access.
# If not set, the Copilot SDK will attempt to use:
#   1. GH_TOKEN environment variable
#   2. GITHUB_TOKEN environment variable
#   3. Stored OAuth credentials from GitHub CLI
GITHUB_TOKEN=

# -----------------------------------------------------------------------------
# Server Authentication
# -----------------------------------------------------------------------------
# Optional API key to protect this server's endpoints.
# If set, clients must send this key via X-API-Key header or Bearer token.
# If not set, the server runs without authentication (suitable for local use).
API_KEY=

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
# Host and port for the uvicorn server.
HOST=0.0.0.0
PORT=8000

# Comma-separated list of allowed CORS origins.
# Use "*" to allow all origins (default).
CORS_ORIGINS=*

# Logging level: debug, info, warning, error, critical
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Frontend Configuration
# -----------------------------------------------------------------------------
# Path to the built frontend static files directory.
# In production, set this to "src/frontend/dist".
# In development, leave empty and run the Vite dev server separately.
FRONTEND_DIR=
